# Postgres connection string (e.g. from a free Supabase project: Project Settings -> Database -> Connection string -> URI)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Admin panel (/admin) credentials — set a strong password and a long random
# secret (e.g. `openssl rand -hex 32`) before deploying. Never reuse the dev values.
ADMIN_PASSWORD="change-me"
ADMIN_SESSION_SECRET="change-me"
